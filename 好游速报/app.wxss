page {
    background-color: #FFFAFA;
  }
  /* 贴子模板 */
.gameList_continer {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
.gameList_continer_box {
    display: flex;
    margin-top: 20px;
    margin-bottom: 10px;
    height: 180px;
    width: 90%;
    border-bottom: 1px solid #cecaca;
  }
.gameList_title {
    margin-left: 20px;
    letter-spacing: 2px;
    margin-top: 10px;
  }
.gameList_content {
    display: flex;
    margin-left: 20px;
  }
  /* 轮播图 */
.swiper_container {
    height: 160px;
    width: 100%;
  }
.swiper_image {
    width: 100%;
    height: 160px;
    border-radius: 10%;
  }
.remarks {
    margin-top: 20px;
    height: auto;
  }
button {
    color: #FF69B4;
    border: 1px solid;
    border-radius: 20px;
    margin: 40px 0 20px 0;
  }
/* 评论区 */
.no-comment {
    margin: 30px 0;
    text-align: center;
    color: #cac4c4;
    font-size: 14px;
  }
.comment {
    display: flex;
    flex-direction: column;
    padding: 10px;
    width: 90%;
    margin-left: 10px;
    border-bottom: 1px solid #ADD8E6;
  }
.comment-list {
    margin: 20px 0;
  }
.comment-item {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
  }
.comment-user {
    margin-left: 10px;
    font-weight: bold;
    margin-right: 10px;
  }
.comment-content {
    flex: 1;
  }
.comment-time {
    font-size: 12px;
    color: #999;
    margin-left: 10px;
  }
/* 评论输入框样式 */
.comment-input {
    display: flex;
    align-items: center;
    background-color: #f9f9f9;
  }
  .comment-input input {
    flex: 1;
    margin: 10px 10px;
    background-color: #f7f3f3;
  }
.comment-input button {
    margin: 0 10px;
    border: none;
    background-color: #f8f5f5;
    color: 	#adada6;
  }
  .header {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 20px;
  }